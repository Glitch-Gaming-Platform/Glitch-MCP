GLITCH_API_BASE_URL=https://api.glitch.fun/api
GLITCH_DASHBOARD_URL=https://app.glitch.fun

# Create a title-scoped MCP token in the Glitch subscription/security
# interface and put it here. Never commit real tokens.
GLITCH_API_TOKEN=

# Optional convenience default. Tools still accept title_id explicitly.
GLITCH_TITLE_ID=

GLITCH_MCP_TIMEOUT_MS=30000

# --- File uploads ---
# Whether glitch_upload_file may read local file paths. Tri-state: leave unset to
# use the transport default (on for stdio, off for the shared HTTP server).
# GLITCH_MCP_ALLOW_LOCAL_FILE_READS=true
# Optional comma-separated real-path roots for stdio file uploads.
# GLITCH_MCP_UPLOAD_ALLOWED_ROOTS=/Users/you/game,/Users/you/Desktop/assets

# --- HTTP transport hardening (only used by `glitch-mcp http`) ---
# Comma-separated hostnames allowed for DNS-rebinding protection when binding to 0.0.0.0/::.
# GLITCH_MCP_ALLOWED_HOSTS=mcp.glitch.fun,localhost
# Optional in-memory edge rate limit (requests/minute/credential). 0 disables.
# GLITCH_MCP_RATE_LIMIT_PER_MINUTE=0

# --- Optional OAuth (disabled by default; bearer-token auth still works) ---
# GLITCH_MCP_OAUTH_ENABLED=false
# GLITCH_MCP_OAUTH_ISSUER=https://auth.glitch.fun
# GLITCH_MCP_OAUTH_RESOURCE_URL=https://mcp.glitch.fun/mcp
# GLITCH_MCP_OAUTH_SCOPES=runs:read,runs:create,actions:read
